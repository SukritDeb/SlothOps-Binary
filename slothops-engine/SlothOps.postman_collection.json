{
  "info": {
    "name": "SlothOps Engine API",
    "description": "API collection for SlothOps automated bug remediation pipeline.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": ["{{base_url}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "List Issues",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/issues",
          "host": ["{{base_url}}"],
          "path": ["issues"]
        }
      }
    },
    {
      "name": "Get Specific Issue",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/issues/{{issue_id}}",
          "host": ["{{base_url}}"],
          "path": ["issues", "{{issue_id}}"]
        }
      }
    },
    {
      "name": "SSE Stream",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Accept", "value": "text/event-stream" }
        ],
        "url": {
          "raw": "{{base_url}}/stream",
          "host": ["{{base_url}}"],
          "path": ["stream"]
        }
      }
    },
    {
      "name": "Sentry Webhook (Simulation Payload)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"data\": {\n    \"event\": {\n      \"exception\": {\n        \"values\": [\n          {\n            \"type\": \"TypeError\",\n            \"value\": \"Simulated Postman Crash\",\n            \"stacktrace\": {\n              \"frames\": [\n                {\n                  \"filename\": \"src/routes/config.ts\",\n                  \"lineno\": 42,\n                  \"function\": \"manualTrigger\"\n                }\n              ]\n            }\n          }\n        ]\n      }\n    }\n  }\n}"
        },
        "url": {
          "raw": "{{base_url}}/webhook/sentry/default_workspace",
          "host": ["{{base_url}}"],
          "path": ["webhook", "sentry", "default_workspace"]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "issue_id",
      "value": "sample-uuid-here",
      "type": "string"
    }
  ]
}
