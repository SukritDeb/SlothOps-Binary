# === SlothOps Engine Environment Variables ===

# OpenAI API Key (required for LLM fix generation)
OPENAI_API_KEY=sk-...

# GitHub Personal Access Token (repo + PR permissions)
GITHUB_TOKEN=ghp_...

# Target GitHub repo in "owner/repo" format
GITHUB_REPO=org/slothops-demo-app

# Sentry webhook secret (optional, for signature verification)
SENTRY_WEBHOOK_SECRET=whsec_...

# SQLite database file path
DATABASE_PATH=./slothops.db

# Server port
PORT=8000

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
