{
  "name": "slothops-demo-app",
  "version": "1.0.0",
  "description": "Target companion app for SlothOps demonstrating automated bug remediation.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc && cp -R src/public dist/public",
